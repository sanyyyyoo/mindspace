# =============================================================================
# Mindspace backend (Render / local) — copy to `backend/.env`
# =============================================================================
#
# Render: Dashboard → Environment → add secrets, then redeploy.
# =============================================================================

SUPABASE_URL=
SUPABASE_KEY=
GROQ_API_KEY=

# CORS: exact browser Origins (scheme + host only, no path). Comma-separated.
# On Render, if unset, the server defaults to the origin in `config/deployedUrls.js`.
# For local development with Vite, set this to the origin where the dev server runs
# (see your Vite terminal output; it is usually printed when you run `npm run dev`).
ALLOWED_ORIGINS=

# Python topic service (optional). Leave unset on Render if you do not run the topic worker.
TOPIC_SERVICE_URL=

# Render injects PORT — do not set manually on Render.
