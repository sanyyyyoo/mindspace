# =============================================================================
# Mindspace backend (Render / local) — copy to `backend/.env`
# =============================================================================
#
# Render: Dashboard → Environment → add each key, then redeploy.
# =============================================================================

# Supabase (service role or anon + RLS; backend uses server-side client)
SUPABASE_URL=
SUPABASE_KEY=

GROQ_API_KEY=

# CORS: exact browser Origins (scheme + host, NO path). Comma-separated.
# Production example (Vercel app only):
#   ALLOWED_ORIGINS=https://mindspace-eight-ruddy.vercel.app
# Local frontend hitting local or remote API:
#   ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: add Vercel + local together while testing:
#   ALLOWED_ORIGINS=https://mindspace-eight-ruddy.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=

# Python topic service (optional). Render: only if you deploy ai-service separately.
TOPIC_SERVICE_URL=http://localhost:5000/analyze-topics

# Render injects PORT automatically — do not set manually on Render.
