# --- Mindspace Express API (Render) ---
# Vercel Production: set to your deployed API origin (scheme + host, no path, no trailing slash).
VITE_API_URL=https://mindspace-j7br.onrender.com
#
# Local dev: point at the Node backend you run on your machine (value is machine-specific; keep in gitignored `.env` only if you prefer not to commit it).
#
# If VITE_API_URL is omitted at build time, the production bundle falls back to the same origin
# defined in `src/config/deployedUrls.js` (keep that file in sync with your Render URL).

# --- Optional: public site URL when `window` is unavailable (tests, tooling) ---
# VITE_SITE_URL=https://mindspace-eight-ruddy.vercel.app
